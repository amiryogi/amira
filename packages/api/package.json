    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
