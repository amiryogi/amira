    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/nodemailer": "^6.4.17",
    "@types/supertest": "^6.0.2",
    "mongodb-memory-server": "^10.4.0",
    "rimraf": "^6.0.0",
